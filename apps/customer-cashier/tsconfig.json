{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@canadian-cart/ui/*": ["../../packages/ui/src/*"],
      "@canadian-cart/db/*": ["../../packages/db/src/*"],
      "@canadian-cart/types/*": ["../../packages/types/src/*"],
      "@canadian-cart/lib/*": ["../../packages/lib/src/*"],
      "@canadian-cart/actions/*": ["../../packages/actions/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
