{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "@canadian-cart/db/*": ["./src/*"],
      "@canadian-cart/types/*": ["../types/src/*"]
    }
  },
  "include": ["src/**/*"]
}
